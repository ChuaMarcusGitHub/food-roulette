# Browser (client) — must be prefixed VITE_ to be exposed by Vite
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
# Server-only (never commit real values)
# Project Settings → API → service_role (for admin purge + cron cleanup)
SUPABASE_SERVICE_ROLE_KEY=

# Optional: override default purge password "angel"
MASTER_DELETE_PASSWORD=

# ⚠️  Service role key bypasses RLS — only safe in a server/edge environment, not a Vite SPA.
# Leave blank unless you've moved admin operations behind a backend.
VITE_SUPABASE_SERVICE_ROLE_KEY=
